# Data source for position: opensky (recommended) or aviationstack
DATA_SOURCE=opensky

# Used to enrich OpenSky tracks with airline, origin, ETA, terminal, gate
AVIATIONSTACK_API_KEY=your_api_key_here

# Your location — used to find the nearest aircraft overhead
OBSERVER_LAT=51.4465501
OBSERVER_LON=-0.2407212

# Only consider aircraft within this radius and altitude band
MAX_DISTANCE_KM=25
MAX_ALTITUDE_FT=12000
MIN_ALTITUDE_FT=500

# How often to refresh (seconds). OpenSky allows one request per 10s without auth.
POLL_INTERVAL_SEC=60

# Set to 1 to print filter diagnostics to stderr
DEBUG_FLIGHTS=0

# Set to 1 to use demo data instead of a live source
USE_MOCK=0
