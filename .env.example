# Get a free key at https://aviationstack.com/signup (100 requests/month)
AVIATIONSTACK_API_KEY=your_api_key_here

# Your location — used to find the nearest aircraft on approach to LHR
OBSERVER_LAT=51.4465501
OBSERVER_LON=-0.2407212

# Only consider aircraft within this radius and altitude band
MAX_DISTANCE_KM=25
MAX_ALTITUDE_FT=12000
MIN_ALTITUDE_FT=500

# How often to refresh flight data (seconds). Live tracking needs frequent polls.
POLL_INTERVAL_SEC=60
